datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                        String          @id @default(uuid())
  createdAt                 DateTime        @default(now())

  email                     String?         @unique
  username                  String?         @unique
  isAdmin                   Boolean         @default(false)

  // Payment scaffolding inherited from OpenSaaS. Unused in the default RMRoads
  // build but kept so forks can opt in to commercialization without re-modeling.
  // The payment/ folder still references these fields; remove them only if you
  // also drop src/payment/ and the related routes from main.wasp.
  paymentProcessorUserId    String?         @unique
  lemonSqueezyCustomerPortalUrl String?
  subscriptionStatus        String?         // 'active', 'cancel_at_period_end', 'past_due', 'deleted'
  subscriptionPlan          String?         // 'hobby', 'pro'
  datePaid                  DateTime?
  credits                   Int             @default(3)

  organizationMemberships   OrganizationMember[]
  sentWorkspaceInvitations   WorkspaceInvitation[] @relation("WorkspaceInvitationSentBy")
  shipmentImports           ShipmentImport[]
  exceptionDecisions        ExceptionDecision[]
}

model Organization {
  id                        String          @id @default(uuid())
  createdAt                 DateTime        @default(now())
  updatedAt                 DateTime        @updatedAt

  name                      String
  slug                      String          @unique
  alertEmailsEnabled        Boolean         @default(false)
  alertRecipients           String          @default("")
  weeklySummaryEmailsEnabled Boolean        @default(false)
  weeklySummaryRecipients   String          @default("")
  weeklySummaryLastSentAt   DateTime?
  weeklySummaryEmailStatus  String          @default("pending")
  pilotMode                 String          @default("demo")
  pilotSuccessMetric        String          @default("Time-to-decision and protected shipment value")
  pilotTargetDecisionHours  Int             @default(4)
  securityReviewCompleted   Boolean         @default(false)

  members                   OrganizationMember[]
  workspaceInvitations      WorkspaceInvitation[]
  shipmentImports           ShipmentImport[]
  shipments                 Shipment[]
  disruptionEvents          DisruptionEvent[]
  shipmentExceptions        ShipmentException[]
  criticalAlerts            CriticalAlert[]
}

model OrganizationMember {
  id                        String          @id @default(uuid())
  createdAt                 DateTime        @default(now())

  organization              Organization    @relation(fields: [organizationId], references: [id])
  organizationId            String

  user                      User            @relation(fields: [userId], references: [id])
  userId                    String

  role                      String          @default("planner")

  @@unique([organizationId, userId])
  @@index([userId])
}

model WorkspaceInvitation {
  id                        String          @id @default(uuid())
  createdAt                 DateTime        @default(now())
  updatedAt                 DateTime        @updatedAt
  acceptedAt                DateTime?
  cancelledAt               DateTime?

  organization              Organization    @relation(fields: [organizationId], references: [id])
  organizationId            String

  email                     String
  role                      String          @default("planner")
  status                    String          @default("pending")
  inviteEmailSentAt         DateTime?
  inviteEmailStatus         String          @default("pending")
  inviteEmailProviderId     String?

  sentBy                    User            @relation("WorkspaceInvitationSentBy", fields: [sentById], references: [id])
  sentById                  String

  @@unique([organizationId, email])
  @@index([organizationId, status])
  @@index([email])
}

model ShipmentImport {
  id                        String          @id @default(uuid())
  createdAt                 DateTime        @default(now())

  organization              Organization    @relation(fields: [organizationId], references: [id])
  organizationId            String

  uploadedBy                User            @relation(fields: [uploadedById], references: [id])
  uploadedById              String

  sourceName                String
  acceptedCount             Int             @default(0)
  rejectedCount             Int             @default(0)
  duplicateCount            Int             @default(0)

  shipments                 Shipment[]

  @@index([organizationId, createdAt])
}

model Shipment {
  id                        String          @id @default(uuid())
  createdAt                 DateTime        @default(now())
  updatedAt                 DateTime        @updatedAt

  organization              Organization    @relation(fields: [organizationId], references: [id])
  organizationId            String

  shipmentImport            ShipmentImport  @relation(fields: [shipmentImportId], references: [id])
  shipmentImportId          String

  externalId                String
  customer                  String
  origin                    String
  destination               String
  mode                      String
  carrier                   String
  plannedShipDate           DateTime
  eta                       DateTime
  priority                  String
  value                     Float
  skuGroup                  String
  destinationLocation       String

  exceptions                ShipmentException[]

  @@unique([organizationId, externalId])
  @@index([organizationId, customer])
  @@index([organizationId, carrier])
  @@index([organizationId, mode])
}

model DisruptionEvent {
  id                        String          @id @default(uuid())
  createdAt                 DateTime        @default(now())
  updatedAt                 DateTime        @updatedAt

  organization              Organization    @relation(fields: [organizationId], references: [id])
  organizationId            String

  type                      String
  severity                  String
  affectedText              String
  mode                      String?
  carrier                   String?
  confidence                Int
  source                    String
  status                    String          @default("active")
  startsAt                  DateTime?
  expiresAt                 DateTime?

  @@index([organizationId, status])
}

model ShipmentException {
  id                        String          @id @default(uuid())
  createdAt                 DateTime        @default(now())
  updatedAt                 DateTime        @updatedAt

  organization              Organization    @relation(fields: [organizationId], references: [id])
  organizationId            String

  shipment                  Shipment        @relation(fields: [shipmentId], references: [id])
  shipmentId                String

  status                    String          @default("new")
  ownerName                 String?
  riskLevel                 String
  riskScore                 Int
  reason                    String

  decisions                 ExceptionDecision[]
  criticalAlerts            CriticalAlert[]

  @@index([organizationId, status])
  @@index([organizationId, riskLevel])
}

model ExceptionDecision {
  id                        String          @id @default(uuid())
  createdAt                 DateTime        @default(now())

  shipmentException         ShipmentException @relation(fields: [shipmentExceptionId], references: [id])
  shipmentExceptionId       String

  decidedBy                 User            @relation(fields: [decidedById], references: [id])
  decidedById               String

  status                    String
  scenarioAction            String
  note                      String
  outcomeStatus             String          @default("pending")
  outcomeNote               String          @default("")
  recommendationInput       Json?
  recommendationOutput      Json?

  @@index([shipmentExceptionId, createdAt])
}

model CriticalAlert {
  id                        String          @id @default(uuid())
  createdAt                 DateTime        @default(now())

  organization              Organization    @relation(fields: [organizationId], references: [id])
  organizationId            String

  shipmentException         ShipmentException @relation(fields: [shipmentExceptionId], references: [id])
  shipmentExceptionId       String

  signature                 String
  message                   String
  sentAt                    DateTime?
  providerMessageId         String?

  @@unique([organizationId, signature])
  @@index([organizationId, createdAt])
}

model PilotLead {
  id                  String   @id @default(uuid())
  createdAt           DateTime @default(now())

  name                String
  workEmail           String
  company             String
  role                String
  shipmentVolume      String
  currentTools        String
  disruptionPain      String
  pilotGoal           String
  status              String   @default("new")

  @@index([createdAt])
  @@index([workEmail])
  @@index([status])
}

model DailyStats {
  id                               Int             @id @default(autoincrement())
  date                             DateTime        @default(now()) @unique

  totalViews                       Int             @default(0)
  prevDayViewsChangePercent        String          @default("0")
  userCount                        Int             @default(0)
  paidUserCount                    Int             @default(0)
  userDelta                        Int             @default(0)
  paidUserDelta                    Int             @default(0)
  totalRevenue                     Float           @default(0)
  totalProfit                      Float           @default(0)

  sources                          PageViewSource[]
}

model PageViewSource {
  @@id([date, name])
  name                     String
  date                     DateTime        @default(now())

  dailyStats               DailyStats?     @relation(fields: [dailyStatsId], references: [id])
  dailyStatsId             Int?

  visitors                 Int
}

model Logs {
  id                       Int             @id @default(autoincrement())
  createdAt                DateTime        @default(now())

  message                  String
  level                    String
}

